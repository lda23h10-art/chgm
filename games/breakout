<!DOCTYPE html>
<html>
<head>
<title>Breakout</title>
<style>
body{
margin:0;
background:black;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}
canvas{
border:2px solid white;
}
</style>
</head>
<body>

<canvas id="game" width="800" height="500"></canvas>

<script>

const canvas=document.getElementById("game");
const ctx=canvas.getContext("2d");

let paddle={
x:350,
y:470,
w:100,
h:15
};

let ball={
x:400,
y:250,
r:10,
dx:4,
dy:-4
};

const bricks=[];

for(let r=0;r<5;r++){
for(let c=0;c<10;c++){
bricks.push({
x:c*75+20,
y:r*30+30,
w:60,
h:20,
alive:true
});
}
}

document.addEventListener("mousemove",e=>{
paddle.x=e.clientX-50;
});

function draw(){

ctx.clearRect(0,0,800,500);

ctx.fillStyle="white";

ctx.fillRect(
paddle.x,
paddle.y,
paddle.w,
paddle.h
);

ctx.beginPath();
ctx.arc(
ball.x,
ball.y,
ball.r,
0,
Math.PI*2
);
ctx.fill();

ball.x+=ball.dx;
ball.y+=ball.dy;

if(ball.x<0||ball.x>800)
ball.dx*=-1;

if(ball.y<0)
ball.dy*=-1;

if(ball.y>500){
alert("Game Over");
location.reload();
}

if(
ball.x>paddle.x &&
ball.x<paddle.x+paddle.w &&
ball.y>paddle.y
){
ball.dy*=-1;
}

bricks.forEach(b=>{

if(!b.alive) return;

ctx.fillRect(
b.x,b.y,b.w,b.h
);

if(
ball.x>b.x &&
ball.x<b.x+b.w &&
ball.y>b.y &&
ball.y<b.y+b.h
){
b.alive=false;
ball.dy*=-1;
}
});

requestAnimationFrame(draw);
}

draw();

</script>

</body>
</html>
